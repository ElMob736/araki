class Conta {
  constructor(titular, saldo = 0) {
    this.titular = titular;
    this.saldo = saldo;
  }

  depositar(valor) {
    this.saldo += valor;
  }

  sacar(valor) {
    if (valor > this.saldo) {
      console.log("Saldo insuficiente");
      return false;
    }
    this.saldo -= valor;
    return true;
  }

  transferir(valor, contaDestino) {
    if (this.sacar(valor)) {
      contaDestino.depositar(valor);
    }
  }
}
