class Produto {
  constructor(nome, estoque) {
    this.nome = nome;
    this.estoque = estoque;
  }

  vender(qtd) {
    if (qtd > this.estoque) {
      console.log("Estoque insuficiente");
      return false;
    }
    this.estoque -= qtd;
    return true;
  }

  repor(qtd) {
    this.estoque += qtd;
  }
}
