class Carrinho {
  constructor() {
    this.produtos = [];
  }

  adicionar(produto) {
    this.produtos.push(produto);
  }

  remover(nome) {
    this.produtos = this.produtos.filter(p => p.nome !== nome);
  }

  calcularTotal() {
    return this.produtos.reduce((total, p) => {
      return total + (p.preco * p.quantidade);
    }, 0);
  }
}
