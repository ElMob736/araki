class Livro {
  constructor(titulo) {
    this.titulo = titulo;
    this.disponivel = true;
  }
}

class Biblioteca {
  constructor() {
    this.livros = [];
  }

  adicionarLivro(livro) {
    this.livros.push(livro);
  }

  emprestar(titulo) {
    const livro = this.livros.find(l => l.titulo === titulo);
    if (livro && livro.disponivel) {
      livro.disponivel = false;
      return true;
    }
    return false;
  }

  devolver(titulo) {
    const livro = this.livros.find(l => l.titulo === titulo);
    if (livro) livro.disponivel = true;
  }
}
