class SistemaLogin {
  constructor() {
    this.usuarios = [];
  }

  cadastrar(email, senha) {
    const existe = this.usuarios.find(u => u.email === email);
    if (existe) {
      console.log("Usuário já existe");
      return false;
    }
    this.usuarios.push({ email, senha });
    return true;
  }

  login(email, senha) {
    return this.usuarios.some(u => u.email === email && u.senha === senha);
  }
}
