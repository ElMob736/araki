class ProdutoPedido {
  constructor(nome, preco) {
    this.nome = nome;
    this.preco = preco;
  }
}

class Pedido {
  constructor(cliente) {
    this.cliente = cliente;
    this.produtos = [];
  }

  adicionarProduto(produto) {
    this.produtos.push(produto);
  }

  calcularTotal() {
    let total = this.produtos.reduce((soma, p) => soma + p.preco, 0);

    // desconto de 10% se passar de 100
    if (total > 100) {
      total *= 0.9;
    }

    return total;
  }
}
