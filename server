import express from 'express'; // Importa o framework
const app = express(); // Inicializa a aplicação
import { filmes, clientes } from './banco-fake.js'

// Habilita o servidor a entender dados em formato JSON
app.use(express.json());

// Define uma rota do tipo GET no endereço /home
app.get('/filmes', (request, response) => {
    return response.json(filmes);
});

app.get('/filmes/:genero', (request, response) => {
    const genero_comp = request.params.genero;

    const fimes_filtrados = filmes.filter(f => f.genero === genero_comp)
    return response.json(fimes_filtrados);
});

